<?xml version="1.0" encoding="utf-8"?>

<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="vm"
            type="com.example.alzcare.ui.patient.make_appointment.PatientAppointmentViewModel" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        tools:context=".ui.patient.make_appointment.PatientAppointmentActivity"
        android:background="@drawable/wavy_background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp">

            <ImageView
                android:id="@+id/back_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_back"
                android:padding="4dp"/>

            <TextView
                android:id="@+id/textViewTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Make an Appointment"
                android:gravity="center"
                android:textSize="20sp"
                android:textColor="@color/white"
                android:fontFamily="@font/montserrat_bold" />
        </LinearLayout>

        <!-- Doctor's Image -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/doc_image"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_doctor"
            android:layout_marginTop="20dp" />

        <!-- Doctor's Name -->
        <TextView
            android:id="@+id/doctor_name_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/doc_image"
            tools:text="Doctor Name"
            android:textColor="@color/white"
            android:fontFamily="@font/montserrat_bold"
            android:padding="10dp" />

        <!-- Doctor's Number -->
        <TextView
            android:id="@+id/doctor_number_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/doc_image"
            tools:text="doctor number"
            android:textColor="@color/white"
            android:fontFamily="@font/montserrat_bold"
            android:padding="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            tools:context=".ui.patient.make_appointment.PatientAppointmentActivity">
            <!-- Check Availability Button -->
            <Button
                android:id="@+id/checkAvailabilityButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Choose a Day"
                android:layout_marginBottom="16dp" />

            <!-- Spinner for Available Times -->
            <Spinner
                android:id="@+id/timeSpinner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="invisible" />

            <!-- Confirm Appointment Button -->
            <Button
                android:id="@+id/confirmAppointmentButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Confirm Appointment"
                android:visibility="invisible" />

        </LinearLayout>
    </LinearLayout>
</layout>
