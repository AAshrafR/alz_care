<?xml version="1.0" encoding="utf-8"?>

<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="vm"
            type="com.example.alzcare.ui.doctor.my_patients.patient_profile.DoctorPatientsViewModel" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        tools:context=".ui.patient.make_appointment.PatientAppointmentActivity"
        android:background="@drawable/wavy_background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp">

            <ImageView
                android:id="@+id/back_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_back"
                android:padding="4dp"/>

            <TextView
                android:id="@+id/textViewTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Patient Account"
                android:gravity="center"
                android:textSize="20sp"
                android:textColor="@color/white"
                android:fontFamily="@font/montserrat_bold" />
        </LinearLayout>

        <!-- Doctor's Image -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/doc_image"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_person"
            android:layout_marginTop="20dp" />

        <!-- Doctor's Name -->
        <TextView
            android:id="@+id/patient_name_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/doc_image"
            tools:text="Patient Name"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:fontFamily="@font/montserrat_bold"
            android:padding="8dp" />

        <!-- Doctor's Number -->
        <TextView
            android:id="@+id/patient_number_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/doc_image"
            tools:text="patient number"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:fontFamily="@font/montserrat_bold"
            android:padding="8dp" />

        <!-- Doctor's Number -->
        <TextView
            android:id="@+id/patient_email_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/doc_image"
            tools:text="Patient email"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:fontFamily="@font/montserrat_bold"
            android:padding="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            tools:context=".ui.patient.make_appointment.PatientAppointmentActivity">

            <ImageView
                android:id="@+id/img_call"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_phone_call"
                android:background="@drawable/background"
                android:padding="10dp"
                android:layout_marginHorizontal="10dp"/>

            <ImageView
                android:id="@+id/img_send_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_send_email"
                android:background="@drawable/background"
                android:padding="10dp"
                android:layout_marginHorizontal="10dp"/>


        </LinearLayout>
    </LinearLayout>
</layout>
